{
  "format_version": 5,
  "tool": "cmake",
  "version": "4.2.3",
  "platform": {
    "os": "linux",
    "arch": "amd64",
    "linux_family": "alpine"
  },
  "deterministic": false,
  "steps": [
    {
      "action": "apk_install",
      "params": {
        "packages": [
          "cmake",
          "cmake-extras"
        ]
      },
      "evaluable": false,
      "deterministic": false
    },
    {
      "action": "install_binaries",
      "params": {
        "binaries": [
          "bin/cmake",
          "bin/ctest",
          "bin/cpack"
        ],
        "install_mode": "directory"
      },
      "evaluable": true,
      "deterministic": true
    }
  ],
  "verify": {
    "command": "cmake --version"
  }
}
